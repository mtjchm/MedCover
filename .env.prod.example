# Production Environment Variables
# Copy this file to .env.prod on your server and fill in all values.
# Never commit .env.prod — it is in .gitignore

# Flask environment — must be production
FLASK_ENV=production

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-strong-random-value

# PostgreSQL — must match the POSTGRES_* values below
DATABASE_URL=postgresql://medcover:<POSTGRES_PASSWORD>@db:5432/medcover_prod

# PostgreSQL container credentials
POSTGRES_DB=medcover_prod
POSTGRES_USER=medcover
POSTGRES_PASSWORD=change-me-use-a-strong-password

# Outbound email (SMTP relay)
# These are the initial defaults; they can also be configured via the admin UI.
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=change-me
MAIL_DEFAULT_SENDER=MedCover <noreply@example.com>

# Developer quick-login — MUST be false in staging/production
DEV_LOGIN_ENABLED=false
